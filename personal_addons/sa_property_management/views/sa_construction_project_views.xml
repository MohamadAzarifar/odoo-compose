<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_sa_construction_project" model="ir.actions.act_window">
        <field name="name">Construction Projects</field>
        <field name="res_model">sa.construction.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_group_state': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first construction project</p>
            <p>Plan phases, award subcontracts, certify work, requisition and
                issue materials, and track budget against actual cost.</p>
        </field>
    </record>

    <record id="view_sa_construction_project_list" model="ir.ui.view">
        <field name="name">sa.construction.project.list</field>
        <field name="model">sa.construction.project</field>
        <field name="arch" type="xml">
            <list string="Construction Projects" decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'done'" decoration-info="state == 'in_progress'">
                <field name="name"/>
                <field name="title"/>
                <field name="property_project_id" optional="show"/>
                <field name="contractor_id" optional="show"/>
                <field name="manager_id" optional="hide"/>
                <field name="date_start" optional="hide"/>
                <field name="date_end_planned" optional="show"/>
                <field name="budget_amount" sum="Budget" optional="show"/>
                <field name="actual_cost" sum="Actual" optional="show"/>
                <field name="cost_variance" sum="Variance" optional="show"
                       decoration-danger="cost_variance &lt; 0"/>
                <field name="progress" widget="progressbar" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'in_progress'"
                       decoration-warning="state == 'on_hold'"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_sa_construction_project_kanban" model="ir.ui.view">
        <field name="name">sa.construction.project.kanban</field>
        <field name="model">sa.construction.project</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="title"/>
                <field name="progress"/>
                <field name="state"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb8">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="title"/></strong>
                                    <small class="o_kanban_record_subtitle text-muted"><field name="name"/></small>
                                </div>
                            </div>
                            <div>
                                <field name="contractor_id"/>
                            </div>
                            <div class="mt4">
                                <field name="budget_amount" widget="monetary"/>
                                <span class="float-end">
                                    <field name="progress" widget="progressbar"/>
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_sa_construction_project_form" model="ir.ui.view">
        <field name="name">sa.construction.project.form</field>
        <field name="model">sa.construction.project</field>
        <field name="arch" type="xml">
            <form string="Construction Project">
                <header>
                    <button name="action_plan" type="object" string="Plan"
                            class="btn-primary" invisible="state not in ('draft', 'on_hold')"/>
                    <button name="action_start" type="object" string="Start"
                            class="btn-primary" invisible="state not in ('planning', 'on_hold')"/>
                    <button name="action_hold" type="object" string="Put on Hold"
                            invisible="state != 'in_progress'"/>
                    <button name="action_resume" type="object" string="Resume"
                            invisible="state != 'on_hold'"/>
                    <button name="action_done" type="object" string="Mark Completed"
                            class="btn-primary" invisible="state != 'in_progress'"/>
                    <button name="action_generate_tasks" type="object" string="Generate Tasks"
                            invisible="state == 'draft'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,planning,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_tasks" type="object" class="oe_stat_button" icon="fa-tasks">
                            <field name="task_count" widget="statinfo" string="Tasks"/>
                        </button>
                        <button name="action_view_contracts" type="object" class="oe_stat_button" icon="fa-handshake-o">
                            <field name="contract_count" widget="statinfo" string="Subcontracts"/>
                        </button>
                        <button name="action_view_requisitions" type="object" class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="requisition_count" widget="statinfo" string="Requisitions"/>
                        </button>
                        <button name="action_view_issues" type="object" class="oe_stat_button" icon="fa-truck">
                            <field name="issue_count" widget="statinfo" string="Issues"/>
                        </button>
                        <button name="action_view_timesheets" type="object" class="oe_stat_button" icon="fa-clock-o">
                            <span class="o_stat_text">Timesheets</span>
                        </button>
                        <button name="action_open_analytic" type="object" class="oe_stat_button" icon="fa-book">
                            <span class="o_stat_text">Cost Ledger</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1><field name="title" placeholder="e.g. Tower A Structure"/></h1>
                        <span class="text-muted"><field name="name" readonly="1"/></span>
                    </div>
                    <group>
                        <group string="Scope">
                            <field name="property_project_id"/>
                            <field name="property_id"/>
                            <field name="manager_id"/>
                            <field name="contractor_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Schedule &amp; Budget">
                            <field name="date_start"/>
                            <field name="date_end_planned"/>
                            <field name="date_end_actual"/>
                            <field name="budget_amount"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="progress" widget="progressbar"/>
                        </group>
                    </group>
                    <group string="Cost Summary" col="4">
                        <field name="actual_cost"/>
                        <field name="committed_cost"/>
                        <field name="cost_variance" decoration-danger="cost_variance &lt; 0"/>
                        <field name="currency_id" column_invisible="1"/>
                        <field name="cost_subcontract"/>
                        <field name="cost_material"/>
                        <field name="cost_labour"/>
                    </group>
                    <notebook>
                        <page string="Phases" name="phases">
                            <field name="phase_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="weight"/>
                                    <field name="progress" widget="progressbar"/>
                                    <field name="state"/>
                                    <field name="date_start" optional="show"/>
                                    <field name="date_end" optional="show"/>
                                    <field name="task_id" optional="hide" readonly="1"/>
                                    <button name="action_create_task" type="object"
                                            string="Create Task" icon="fa-tasks"
                                            invisible="task_id != False"/>
                                </list>
                            </field>
                        </page>
                        <page string="Scope of Work" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sa_construction_project_search" model="ir.ui.view">
        <field name="name">sa.construction.project.search</field>
        <field name="model">sa.construction.project</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="title"/>
                <field name="property_project_id"/>
                <field name="contractor_id"/>
                <field name="manager_id"/>
                <filter name="my_projects" string="My Projects"
                        domain="[('manager_id', '=', uid)]"/>
                <separator/>
                <filter name="in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                <filter name="planning" string="Planning" domain="[('state', '=', 'planning')]"/>
                <filter name="done" string="Completed" domain="[('state', '=', 'done')]"/>
                <group>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_property_project" string="Property Project"
                            context="{'group_by': 'property_project_id'}"/>
                    <filter name="group_contractor" string="Contractor"
                            context="{'group_by': 'contractor_id'}"/>
                    <filter name="group_manager" string="Manager"
                            context="{'group_by': 'manager_id'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
