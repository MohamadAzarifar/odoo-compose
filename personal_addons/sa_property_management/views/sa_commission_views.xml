<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sa_commission_list" model="ir.ui.view">
        <field name="name">sa.commission.list</field>
        <field name="model">sa.commission</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'paid'"
                  decoration-info="state == 'billed'">
                <field name="name"/>
                <field name="date"/>
                <field name="beneficiary_type"/>
                <field name="partner_id"/>
                <field name="property_id"/>
                <field name="booking_id"/>
                <field name="base_amount" sum="Base"/>
                <field name="commission_percent"/>
                <field name="commission_amount" sum="Commission"/>
                <field name="bill_payment_state" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'paid'"
                       decoration-info="state == 'billed'"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="company_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_sa_commission_form" model="ir.ui.view">
        <field name="name">sa.commission.form</field>
        <field name="model">sa.commission</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_create_vendor_bill" type="object"
                            string="Create Vendor Bill" class="btn-primary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_mark_paid" type="object"
                            string="Mark Paid" invisible="state != 'billed'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('cancelled', 'paid')"/>
                    <button name="action_reset_to_draft" type="object"
                            string="Reset to Draft" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,billed,paid"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bill" type="object"
                                class="oe_stat_button" icon="fa-money"
                                invisible="bill_count == 0">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Vendor Bill</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="beneficiary_type"/>
                            <field name="partner_id"
                                   readonly="state not in ('draft',)"/>
                            <field name="dealer_id"
                                   invisible="beneficiary_type != 'dealer'"
                                   readonly="state not in ('draft',)"/>
                            <field name="date" readonly="state not in ('draft',)"/>
                        </group>
                        <group>
                            <field name="booking_id"
                                   readonly="state not in ('draft',)"/>
                            <field name="property_id" readonly="1"/>
                            <field name="base_amount"
                                   readonly="state not in ('draft',)"/>
                            <field name="commission_percent"
                                   readonly="state not in ('draft',)"/>
                            <field name="commission_amount"
                                   readonly="state not in ('draft',)"/>
                            <field name="bill_payment_state"
                                   invisible="not vendor_bill_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="bill_count" invisible="1"/>
                            <field name="vendor_bill_id" invisible="1"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Internal notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sa_commission_search" model="ir.ui.view">
        <field name="name">sa.commission.search</field>
        <field name="model">sa.commission</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="property_id"/>
                <field name="booking_id"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="billed" string="Billed" domain="[('state', '=', 'billed')]"/>
                <filter name="paid" string="Paid" domain="[('state', '=', 'paid')]"/>
                <separator/>
                <filter name="dealers" string="Dealers" domain="[('beneficiary_type', '=', 'dealer')]"/>
                <filter name="investors" string="Investors" domain="[('beneficiary_type', '=', 'investor')]"/>
                <group>
                    <filter name="group_beneficiary" string="Beneficiary"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'beneficiary_type'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sa_commission" model="ir.actions.act_window">
        <field name="name">Commissions</field>
        <field name="res_model">sa.commission</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_state': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No commissions yet
            </p>
            <p>
                Commissions are generated automatically when a booking with a
                dealer is confirmed, and can be paid through standard vendor bills.
            </p>
        </field>
    </record>

</odoo>
