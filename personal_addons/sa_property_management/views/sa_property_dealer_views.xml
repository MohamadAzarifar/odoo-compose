<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sa_property_dealer_tree" model="ir.ui.view">
        <field name="name">sa.property.dealer.tree</field>
        <field name="model">sa.property.dealer</field>
        <field name="arch" type="xml">
            <list string="Dealers">
                <field name="code"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="cnic" optional="hide"/>
                <field name="ntn" optional="hide"/>
                <field name="commission_percent"/>
                <field name="booking_count"/>
                <field name="total_sales" sum="Total"/>
                <field name="total_commission" sum="Total"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_sa_property_dealer_form" model="ir.ui.view">
        <field name="name">sa.property.dealer.form</field>
        <field name="model">sa.property.dealer</field>
        <field name="arch" type="xml">
            <form string="Dealer">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bookings" type="object"
                                class="oe_stat_button" icon="fa-handshake-o">
                            <field name="booking_count" widget="statinfo" string="Bookings"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="partner_id"/>
                        <h1><field name="partner_id" options="{'no_quick_create': True}"/></h1>
                        <field name="code" readonly="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="phone"/>
                            <field name="email" widget="email"/>
                            <field name="cnic"/>
                            <field name="ntn"/>
                        </group>
                        <group>
                            <field name="commission_percent"/>
                            <field name="total_sales" readonly="1"/>
                            <field name="total_commission" readonly="1"/>
                            <field name="active" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Assigned Projects">
                            <field name="project_ids"/>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_sa_property_dealer" model="ir.actions.act_window">
        <field name="name">Dealers</field>
        <field name="res_model">sa.property.dealer</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
