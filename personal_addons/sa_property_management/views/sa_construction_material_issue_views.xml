<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_sa_construction_material_issue" model="ir.actions.act_window">
        <field name="name">Material Issues</field>
        <field name="res_model">sa.construction.material.issue</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Issue materials to the site</p>
            <p>Transfer stock to the construction site and book the material
                cost against the project budget.</p>
        </field>
    </record>

    <record id="view_sa_construction_material_issue_list" model="ir.ui.view">
        <field name="name">sa.construction.material.issue.list</field>
        <field name="model">sa.construction.material.issue</field>
        <field name="arch" type="xml">
            <list string="Material Issues" decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'done'">
                <field name="name"/>
                <field name="construction_id"/>
                <field name="date"/>
                <field name="amount_total" sum="Total Cost"/>
                <field name="state" widget="badge" decoration-success="state == 'done'"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_sa_construction_material_issue_form" model="ir.ui.view">
        <field name="name">sa.construction.material.issue.form</field>
        <field name="model">sa.construction.material.issue</field>
        <field name="arch" type="xml">
            <form string="Material Issue">
                <header>
                    <button name="action_issue" type="object" string="Issue to Site"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_picking" type="object"
                                class="oe_stat_button" icon="fa-truck"
                                invisible="picking_id == False">
                            <span class="o_stat_text">Transfer</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="construction_id" readonly="state != 'draft'"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="picking_id" readonly="1" invisible="picking_id == False"/>
                            <field name="amount_total"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Materials" name="materials">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="uom_id" optional="show"/>
                                    <field name="quantity"/>
                                    <field name="unit_cost"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sa_construction_material_issue_search" model="ir.ui.view">
        <field name="name">sa.construction.material.issue.search</field>
        <field name="model">sa.construction.material.issue</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="construction_id"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="done" string="Issued" domain="[('state', '=', 'done')]"/>
                <group>
                    <filter name="group_construction" string="Construction Project"
                            context="{'group_by': 'construction_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
