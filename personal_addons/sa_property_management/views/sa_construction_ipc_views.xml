<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_sa_construction_ipc" model="ir.actions.act_window">
        <field name="name">Payment Certificates</field>
        <field name="res_model">sa.construction.ipc</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Certify subcontractor progress</p>
            <p>Approve interim payment certificates and post the corresponding
                vendor bills to the construction cost ledger.</p>
        </field>
    </record>

    <record id="view_sa_construction_ipc_list" model="ir.ui.view">
        <field name="name">sa.construction.ipc.list</field>
        <field name="model">sa.construction.ipc</field>
        <field name="arch" type="xml">
            <list string="Payment Certificates" decoration-info="state == 'approved'"
                  decoration-success="state == 'billed'">
                <field name="name"/>
                <field name="contract_id"/>
                <field name="construction_id" optional="show"/>
                <field name="contractor_id" optional="show"/>
                <field name="date"/>
                <field name="amount_gross" sum="Gross"/>
                <field name="retention_amount" sum="Retention"/>
                <field name="amount_net" sum="Net"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'approved'"
                       decoration-success="state == 'billed'"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_sa_construction_ipc_form" model="ir.ui.view">
        <field name="name">sa.construction.ipc.form</field>
        <field name="model">sa.construction.ipc</field>
        <field name="arch" type="xml">
            <form string="Payment Certificate">
                <header>
                    <button name="action_approve" type="object" string="Approve"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_create_bill" type="object" string="Create Vendor Bill"
                            class="btn-primary" invisible="state != 'approved'"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bill" type="object" class="oe_stat_button"
                                icon="fa-money" invisible="bill_id == False">
                            <span class="o_stat_text">Vendor Bill</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="contract_id" readonly="state != 'draft'"/>
                            <field name="construction_id" readonly="1"/>
                            <field name="contractor_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="retention_percent"/>
                            <field name="bill_state" invisible="bill_id == False"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Certified Work" name="lines">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="boq_line_id"/>
                                    <field name="name"/>
                                    <field name="uom_id" optional="show"/>
                                    <field name="qty_remaining" optional="show"/>
                                    <field name="quantity"/>
                                    <field name="unit_rate"/>
                                    <field name="amount" sum="Gross"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="amount_gross"/>
                                <field name="retention_amount"/>
                                <field name="amount_net" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sa_construction_ipc_search" model="ir.ui.view">
        <field name="name">sa.construction.ipc.search</field>
        <field name="model">sa.construction.ipc</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="contract_id"/>
                <field name="construction_id"/>
                <field name="contractor_id"/>
                <filter name="to_approve" string="To Approve" domain="[('state', '=', 'draft')]"/>
                <filter name="to_bill" string="To Bill" domain="[('state', '=', 'approved')]"/>
                <group>
                    <filter name="group_construction" string="Construction Project"
                            context="{'group_by': 'construction_id'}"/>
                    <filter name="group_contract" string="Subcontract"
                            context="{'group_by': 'contract_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
