<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_sa_construction_contract" model="ir.actions.act_window">
        <field name="name">Subcontracts</field>
        <field name="res_model">sa.construction.contract</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Award your first subcontract</p>
            <p>Capture the bill of quantities and certify progress through
                interim payment certificates.</p>
        </field>
    </record>

    <record id="view_sa_construction_contract_list" model="ir.ui.view">
        <field name="name">sa.construction.contract.list</field>
        <field name="model">sa.construction.contract</field>
        <field name="arch" type="xml">
            <list string="Subcontracts" decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'closed'">
                <field name="name"/>
                <field name="title"/>
                <field name="construction_id"/>
                <field name="contractor_id"/>
                <field name="contract_value" sum="Value"/>
                <field name="amount_certified" sum="Certified"/>
                <field name="amount_billed" sum="Billed"/>
                <field name="progress" widget="progressbar"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'closed'"
                       decoration-info="state == 'in_progress'"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_sa_construction_contract_form" model="ir.ui.view">
        <field name="name">sa.construction.contract.form</field>
        <field name="model">sa.construction.contract</field>
        <field name="arch" type="xml">
            <form string="Subcontract">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_start" type="object" string="Start Work"
                            invisible="state != 'confirmed'"/>
                    <button name="action_create_ipc" type="object" string="New Certificate"
                            class="btn-primary" invisible="state not in ('confirmed', 'in_progress')"/>
                    <button name="action_close" type="object" string="Close"
                            invisible="state not in ('confirmed', 'in_progress')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('closed', 'cancelled')"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="state not in ('cancelled',)"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_progress,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_ipcs" type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="ipc_count" widget="statinfo" string="Certificates"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1><field name="title" placeholder="e.g. RCC &amp; Masonry Works"/></h1>
                        <span class="text-muted"><field name="name" readonly="1"/></span>
                    </div>
                    <group>
                        <group>
                            <field name="construction_id"
                                   readonly="state != 'draft'"/>
                            <field name="contractor_id"/>
                            <field name="retention_percent"/>
                        </group>
                        <group>
                            <field name="date_signed"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bill of Quantities" name="boq">
                            <field name="boq_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="uom_id" optional="show"/>
                                    <field name="quantity"/>
                                    <field name="unit_rate"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="qty_certified" optional="show"/>
                                    <field name="qty_remaining" optional="show"/>
                                    <field name="progress" widget="progressbar" optional="hide"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="contract_value"/>
                                <field name="amount_certified"/>
                                <field name="amount_retained"/>
                                <field name="amount_remaining"/>
                            </group>
                        </page>
                        <page string="Terms" name="terms">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sa_construction_contract_search" model="ir.ui.view">
        <field name="name">sa.construction.contract.search</field>
        <field name="model">sa.construction.contract</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="title"/>
                <field name="construction_id"/>
                <field name="contractor_id"/>
                <filter name="open" string="Open"
                        domain="[('state', 'in', ('confirmed', 'in_progress'))]"/>
                <group>
                    <filter name="group_construction" string="Construction Project"
                            context="{'group_by': 'construction_id'}"/>
                    <filter name="group_contractor" string="Subcontractor"
                            context="{'group_by': 'contractor_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
