<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Country-aware miscellaneous charges. Charges tagged with a country
             apply only for that operating country; leave the country empty to
             apply a charge everywhere. -->

        <!-- ===================== Pakistan ===================== -->
        <record id="misc_file_transfer" model="sa.misc.charge">
            <field name="name">File Transfer Fee</field>
            <field name="code">FILE_TRF</field>
            <field name="country_id" ref="base.pk"/>
            <field name="sequence">10</field>
            <field name="amount_type">fixed</field>
            <field name="amount">25000.0</field>
            <field name="payer">buyer</field>
            <field name="apply_on">transfer</field>
        </record>

        <record id="misc_society_dues" model="sa.misc.charge">
            <field name="name">Society Membership / Dues</field>
            <field name="code">SOC_DUES</field>
            <field name="country_id" ref="base.pk"/>
            <field name="sequence">20</field>
            <field name="amount_type">fixed</field>
            <field name="amount">15000.0</field>
            <field name="payer">buyer</field>
            <field name="apply_on">transfer</field>
        </record>

        <record id="misc_utility_transfer" model="sa.misc.charge">
            <field name="name">Utility Connection Transfer</field>
            <field name="code">UTIL_TRF</field>
            <field name="country_id" ref="base.pk"/>
            <field name="sequence">30</field>
            <field name="amount_type">fixed</field>
            <field name="amount">10000.0</field>
            <field name="payer">buyer</field>
            <field name="apply_on">transfer</field>
        </record>

        <record id="misc_noc_fee" model="sa.misc.charge">
            <field name="name">NOC Fee</field>
            <field name="code">NOC</field>
            <field name="country_id" ref="base.pk"/>
            <field name="sequence">40</field>
            <field name="amount_type">fixed</field>
            <field name="amount">5000.0</field>
            <field name="payer">seller</field>
            <field name="apply_on">transfer</field>
        </record>

        <record id="misc_development_charge" model="sa.misc.charge">
            <field name="name">Development Charges (per Marla)</field>
            <field name="code">DEV_CHG</field>
            <field name="country_id" ref="base.pk"/>
            <field name="sequence">50</field>
            <field name="amount_type">per_unit_area</field>
            <field name="amount">5000.0</field>
            <field name="payer">buyer</field>
            <field name="apply_on">booking</field>
        </record>

        <!-- ============== Global (apply in any country) ============== -->
        <record id="misc_legal_fee" model="sa.misc.charge">
            <field name="name">Legal / Conveyancing Fee</field>
            <field name="code">LEGAL</field>
            <field name="sequence">100</field>
            <field name="amount_type">percent</field>
            <field name="rate">0.5</field>
            <field name="payer">buyer</field>
            <field name="apply_on">transfer</field>
        </record>

        <record id="misc_agency_fee" model="sa.misc.charge">
            <field name="name">Agency / Brokerage Fee</field>
            <field name="code">AGENCY</field>
            <field name="sequence">110</field>
            <field name="amount_type">percent</field>
            <field name="rate">2.0</field>
            <field name="payer">seller</field>
            <field name="apply_on">transfer</field>
        </record>

    </data>
</odoo>
