<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sa_booking_confirm_wizard_form" model="ir.ui.view">
        <field name="name">sa.booking.confirm.wizard.form</field>
        <field name="model">sa.booking.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm Booking - Preview Schedule">
                <group>
                    <group>
                        <field name="booking_id" invisible="1"/>
                        <field name="payment_plan_id" options="{'no_create': True}"/>
                        <field name="booking_date"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="total_price"/>
                    </group>
                </group>
                <separator string="Schedule Preview"/>
                <field name="preview_line_ids" readonly="1">
                    <list create="false" delete="false" edit="false">
                        <field name="sequence"/>
                        <field name="name"/>
                        <field name="line_type"/>
                        <field name="due_date"/>
                        <field name="amount" sum="Total"/>
                        <field name="currency_id" invisible="1"/>
                    </list>
                </field>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Confirm Booking" class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sa_booking_confirm_wizard" model="ir.actions.act_window">
        <field name="name">Confirm Booking</field>
        <field name="res_model">sa.booking.confirm.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_sa_property_booking"/>
        <field name="binding_view_types">form</field>
    </record>

</odoo>
