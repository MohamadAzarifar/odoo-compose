<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sa_misc_charge_tree" model="ir.ui.view">
        <field name="name">sa.misc.charge.tree</field>
        <field name="model">sa.misc.charge</field>
        <field name="arch" type="xml">
            <list string="Misc Charges">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="country_id" optional="show"/>
                <field name="amount_type"/>
                <field name="amount"/>
                <field name="rate" optional="hide"/>
                <field name="payer"/>
                <field name="apply_on"/>
                <field name="account_id"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_sa_misc_charge_form" model="ir.ui.view">
        <field name="name">sa.misc.charge.form</field>
        <field name="model">sa.misc.charge</field>
        <field name="arch" type="xml">
            <form string="Misc Charge">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active"/>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="country_id"/>
                            <field name="sequence"/>
                            <field name="active" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="amount_type"/>
                            <field name="amount" invisible="amount_type == 'percent'"/>
                            <field name="rate" invisible="amount_type != 'percent'"
                                   required="amount_type == 'percent'"/>
                            <field name="payer"/>
                            <field name="apply_on"/>
                            <field name="account_id"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sa_misc_charge" model="ir.actions.act_window">
        <field name="name">Misc Charges</field>
        <field name="res_model">sa.misc.charge</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
