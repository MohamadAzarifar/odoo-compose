<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_crm_lead_form_sa_property" model="ir.ui.view">
        <field name="name">crm.lead.form.sa.property</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_sa_view_bookings" type="object"
                        class="oe_stat_button" icon="fa-home"
                        invisible="sa_booking_count == 0">
                    <field name="sa_booking_count" widget="statinfo"
                           string="Bookings"/>
                </button>
                <button name="action_sa_create_booking" type="object"
                        class="oe_stat_button" icon="fa-plus-square-o"
                        string="Create Booking"
                        invisible="sa_booking_count != 0"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Real Estate" name="sa_real_estate">
                    <group>
                        <group string="Interest">
                            <field name="sa_project_id"/>
                            <field name="sa_property_id"
                                   options="{'no_create': True}"/>
                            <field name="sa_property_type"/>
                            <field name="sa_purpose"/>
                            <field name="sa_area_preference"/>
                        </group>
                        <group string="Budget &amp; Source">
                            <field name="company_currency" invisible="1"/>
                            <field name="sa_budget_min"/>
                            <field name="sa_budget_max"/>
                            <field name="sa_source_id" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_sa_crm_lead" model="ir.actions.act_window">
        <field name="name">Property Leads</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,kanban,form,calendar,activity</field>
        <field name="domain">[('type', '=', 'lead')]</field>
        <field name="context">{'default_type': 'lead'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No property leads yet</p>
            <p>Leads captured from your integrations (Meta, Apollo, website, ...)
               and manual entries appear here, ready to qualify and convert.</p>
        </field>
    </record>

    <record id="action_sa_crm_opportunity" model="ir.actions.act_window">
        <field name="name">Opportunities</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form,calendar,activity</field>
        <field name="domain">[('type', '=', 'opportunity')]</field>
        <field name="context">{'default_type': 'opportunity'}</field>
    </record>

</odoo>
