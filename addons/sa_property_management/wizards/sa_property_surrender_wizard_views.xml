<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sa_property_surrender_wizard_form" model="ir.ui.view">
        <field name="name">sa.property.surrender.wizard.form</field>
        <field name="model">sa.property.surrender.wizard</field>
        <field name="arch" type="xml">
            <form string="Surrender Unit">
                <group>
                    <group>
                        <field name="property_id" options="{'no_create': True}"
                               readonly="context.get('default_property_id')"/>
                        <field name="booking_id" options="{'no_create': True}"/>
                        <field name="customer_id"/>
                        <field name="surrender_date"/>
                    </group>
                    <group>
                        <field name="amount_paid"/>
                        <field name="deduction_amount"/>
                        <field name="refund_amount"/>
                        <field name="create_refund"/>
                        <field name="note" placeholder="Optional reference"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Confirm Surrender" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
