<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sa_property_buyback_wizard_form" model="ir.ui.view">
        <field name="name">sa.property.buyback.wizard.form</field>
        <field name="model">sa.property.buyback.wizard</field>
        <field name="arch" type="xml">
            <form string="Buy Back Unit">
                <group>
                    <group>
                        <field name="property_id" options="{'no_create': True}"
                               readonly="context.get('default_property_id')"/>
                        <field name="partner_id"/>
                        <field name="buyback_date"/>
                    </group>
                    <group>
                        <field name="buyback_amount"/>
                        <field name="create_bill"/>
                        <field name="note" placeholder="Optional reference"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Confirm Buy-Back" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
