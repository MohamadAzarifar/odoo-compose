<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_users_form_jalali_calendar" model="ir.ui.view">
        <field name="name">res.users.form.jalali.calendar</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='other_preferences']" position="inside">
                <field name="use_jalali_calendar"/>
            </xpath>
        </field>
    </record>

    <record id="view_users_form_simple_modif_jalali_calendar" model="ir.ui.view">
        <field name="name">res.users.preferences.form.jalali.calendar</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='other_preferences']" position="inside">
                <field name="use_jalali_calendar"/>
            </xpath>
        </field>
    </record>

</odoo>
