# Copy to .env (start.sh does this automatically) and customize as needed.
# Never commit .env.

# PostgreSQL
POSTGRES_USER=odoo
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Odoo master password (database manager / create DB)
ODOO_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Published ports
HTTP_PORT=80
HTTPS_PORT=443

# Optional HTTPS (used by scripts/enable-https.sh)
# DOMAIN must point to this server's public IP before enabling HTTPS.
DOMAIN=
EMAIL=
